# Copy this file to .env and replace values for your local environment.
# Spring Boot loads this file through spring.config.import=optional:file:.env[.properties].

# Shared
NBATCH_ACCESS_TOKEN=default_token

# Admin datasource
NBATCH_ADMIN_DATASOURCE_URL=jdbc:mysql://localhost:3306/batch_dev?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8&nullCatalogMeansCurrent=true
NBATCH_ADMIN_DATASOURCE_USERNAME=root
NBATCH_ADMIN_DATASOURCE_PASSWORD=
NBATCH_ADMIN_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver

# Admin mail
NBATCH_MAIL_HOST=smtp.qq.com
NBATCH_MAIL_PORT=25
NBATCH_MAIL_USERNAME=
NBATCH_MAIL_FROM=
NBATCH_MAIL_PASSWORD=

# Admin runtime
NBATCH_ADMIN_TIMEOUT=3
NBATCH_ADMIN_I18N=zh_CN
NBATCH_ADMIN_LOG_RETENTION_DAYS=30

# Consumer admin registration
NBATCH_ADMIN_ADDRESSES=http://localhost:8095/nbatch
NBATCH_CONSUMER_ADMIN_TIMEOUT=3

# Consumer executor
NBATCH_EXECUTOR_APP_NAME=nbatch-consumer
NBATCH_EXECUTOR_ADDRESS=
NBATCH_EXECUTOR_IP=
NBATCH_EXECUTOR_PORT=9999
NBATCH_EXECUTOR_LOG_PATH=/log/nbatch/jobhandler
NBATCH_EXECUTOR_DATA_PATH=/data/nbatch/jobhandler
NBATCH_EXECUTOR_LOG_RETENTION_DAYS=30

# Consumer data paths
NBATCH_FILE_TEMP_PATH=./file/temp
NBATCH_FILE_REMOTE_TEMP_PATH=./file/temp

# Consumer dynamic datasources
NBATCH_GAUSS_DATASOURCE_URL=jdbc:opengauss://localhost:5432/postgres?currentSchema=public&serverTimezone=Asia/Shanghai
NBATCH_GAUSS_DATASOURCE_USERNAME=
NBATCH_GAUSS_DATASOURCE_PASSWORD=
NBATCH_GAUSS_DATASOURCE_DRIVER=org.opengauss.Driver

NBATCH_CLICKHOUSE_DATASOURCE_URL=jdbc:clickhouse://localhost:8123/default?compress=0
NBATCH_CLICKHOUSE_DATASOURCE_USERNAME=default
NBATCH_CLICKHOUSE_DATASOURCE_PASSWORD=
NBATCH_CLICKHOUSE_DATASOURCE_DRIVER=com.clickhouse.jdbc.ClickHouseDriver

NBATCH_GBASE_DATASOURCE_URL=jdbc:gbase://localhost:5258/default
NBATCH_GBASE_DATASOURCE_USERNAME=
NBATCH_GBASE_DATASOURCE_PASSWORD=
NBATCH_GBASE_DATASOURCE_DRIVER=com.gbase.jdbc.Driver
